{
  "entities": {
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "System-wide settings managed by Super Admin.",
      "type": "object",
      "properties": {
        "presetCreditDeduct": {
          "type": "number",
          "description": "Cost to test a preset."
        }
      },
      "required": ["presetCreditDeduct"]
    },
    "Preset": {
      "title": "AI Preset",
      "description": "An AI style preset.",
      "type": "object",
      "properties": {
        "styleName": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "promptFragment": {
          "type": "string"
        },
        "thumbnailBase64": {
          "type": "string"
        }
      },
      "required": ["styleName", "category", "promptFragment", "thumbnailBase64"]
    },
    "Reseller": {
      "title": "Reseller Tenant",
      "description": "A tenant account for a reseller.",
      "type": "object",
      "properties": {
        "brandName": {
          "type": "string"
        },
        "subdomain": {
          "type": "string"
        },
        "creditsBalance": {
          "type": "number"
        },
        "maintenanceMode": {
          "type": "boolean"
        },
        "gcashNumber": {
          "type": "string"
        },
        "priceSingle": {
          "type": "number"
        },
        "creditsSingle": {
          "type": "number"
        },
        "currentOverlayUrl": {
          "type": "string"
        },
        "ownerUid": {
          "type": "string"
        }
      },
      "required": ["brandName", "subdomain", "creditsBalance", "maintenanceMode", "ownerUid"]
    },
    "User": {
      "title": "End User",
      "description": "A user registered under a specific reseller.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "credits": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": ["verified", "banned"]
        },
        "totalCreditPurchased": {
          "type": "number"
        },
        "photosGenerated": {
          "type": "number"
        }
      },
      "required": ["uid", "email", "displayName", "credits", "status", "totalCreditPurchased", "photosGenerated"]
    },
    "Transaction": {
      "title": "Top-Up Transaction",
      "description": "A GCash top-up request.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "credits": {
          "type": "number"
        },
        "gcashReference": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "verified", "rejected"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "amount", "credits", "gcashReference", "status", "createdAt"]
    },
    "Photo": {
      "title": "Generated Photo",
      "description": "A photo generated by the user.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "imageUrl": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "imageUrl", "createdAt"]
    }
  },
  "firestore": {
    "/globalSettings/{docId}": {
      "schema": {
        "$ref": "#/entities/GlobalSettings"
      },
      "description": "Global settings."
    },
    "/presets/{presetId}": {
      "schema": {
        "$ref": "#/entities/Preset"
      },
      "description": "Global presets."
    },
    "/resellers/{resellerId}": {
      "schema": {
        "$ref": "#/entities/Reseller"
      },
      "description": "Reseller tenants."
    },
    "/resellers/{resellerId}/PRESETS/{presetId}": {
      "schema": {
        "$ref": "#/entities/Preset"
      },
      "description": "Reseller's custom presets."
    },
    "/resellers/{resellerId}/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "End users for a reseller."
    },
    "/resellers/{resellerId}/users/{userId}/transactions/{txId}": {
      "schema": {
        "$ref": "#/entities/Transaction"
      },
      "description": "Transactions for a user."
    },
    "/resellers/{resellerId}/users/{userId}/gallery/{photoId}": {
      "schema": {
        "$ref": "#/entities/Photo"
      },
      "description": "Generated photos for a user."
    }
  }
}
